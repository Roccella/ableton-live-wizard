{
  "name": "ableton-live-wizard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MVP1 scaffold for Ableton Live Wizard",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --enable-source-maps --loader ts-node/esm src/cli.ts",
    "dev:bridge-stub": "node --enable-source-maps --loader ts-node/esm src/dev/bridge-stub.ts",
    "start": "node dist/src/cli.js",
    "test": "node --test dist/test/*.test.js",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@types/blessed": "^0.1.27",
    "neo-blessed": "^0.2.0"
  }
}
